{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "lib": ["ES2020"]
  },
  "include": ["scripts", "test", "examples", "typechain-types"],
  "exclude": ["node_modules", "dist", "artifacts", "cache"]
}
