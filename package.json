{
  "name": "@opacus-xyz/agent-h3-routing",
  "version": "1.0.0",
  "description": "ERC-8242 H3 Spatial Identity Extension — reference implementation, interface, tests, and integration examples.",
  "keywords": [
    "erc-8242",
    "h3",
    "spatial",
    "agents",
    "ethereum",
    "solidity",
    "eip"
  ],
  "homepage": "https://github.com/Opacus-xyz/Agent-H3-Routing",
  "repository": {
    "type": "git",
    "url": "https://github.com/Opacus-xyz/Agent-H3-Routing.git"
  },
  "license": "CC0-1.0",
  "author": "Opacus Protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "contracts/**/*.sol",
    "artifacts/contracts/**/*.json",
    "dist/**",
    "examples/**"
  ],
  "scripts": {
    "build": "tsc",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network base",
    "verify": "hardhat verify --network baseSepolia",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "lint:ts": "eslint 'test/**/*.ts' 'examples/**/*.ts' 'scripts/**/*.ts'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "ethers": "^6.0.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.0",
    "solhint": "^4.0.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.9.0",
    "typechain": "^8.0.0",
    "typescript": "^5.0.0",
    "viem": "^2.0.0"
  },
  "peerDependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
